#: includes/template-tags/class-post-template-tags.php:320
msgid ""
"<strong>Output</strong>: <strong>first</strong> or <strong>last</strong> "
"image source ( src=\"\" ) from post content\n"
"\t\t\t\t<br /><br /><strong>Attributes:</strong>\n"
"\t\t\t\t<br /><strong>position</strong> = ( first|last )\n"
"\t\t\t\t<br /><strong>output</strong> = ( text|number ),\n"
"\t\t\t\t<br />----\"src\" - will return src of the image,\n"
"\t\t\t\t<br />----by default it will return image html\n"
"\t\t\t\t<br /><strong>class</strong> = ( string ), class name for the image "
"( &lt;img /&gt; ) tag\n"
"\t\t\t\t<br /><strong>width</strong> = ( number ), set image width attr ( "
"image scaling, not resizing )\n"
"\t\t\t\t<br /><strong>height</strong> = ( number ), set image height attr ( "
"image scaling, not resizing )\n"
"\t\t\t\t<br /><strong>use_fallback</strong> = ( true|false ), set 1 to use "
"<code>[featured_image]</code> shortcode as fallback while post content dont "
"have any images."
msgstr ""

#: includes/template-tags/class-post-template-tags.php:338
msgid ""
"<strong>Output</strong>: post meta value. if return value is an array, it "
"will be migrated to string by using explode function\n"
"\t\t\t\t<br /><br /><strong>Attributes:</strong>\n"
"\t\t\t\t<br /><strong>key</strong> = ( text|number ), meta key name\n"
"\t\t\t\t<br /><strong>sub_key</strong> = ( text|number ), if meta value is "
"array|object, display a specific value by it's key\n"
"\t\t\t\t<br /><strong>multiple</strong> = ( 0|1 ), display meta value at "
"multiple occurence\n"
"\t\t\t\t<br /><strong>sep</strong> = ( text ), separate array meta value "
"into string"
msgstr ""

#: includes/template-tags/class-post-template-tags.php:352
msgid ""
"<strong>Output</strong>: post meta value. if return value is an array, it "
"will be migrated to string by using explode function\n"
"\t\t\t\t<br /><br /><strong>Attributes:</strong>\n"
"\t\t\t\t<br /><strong>key</strong> = ( text|number ), meta key name"
msgstr ""

#: includes/template-tags/class-post-template-tags.php:363
msgid ""
"<strong>Output</strong>: post type terms. if return value is an array, it "
"will be migrated to string by using explode function\n"
"\t\t\t\t<br /><br /><strong>Attributes:</strong>\n"
"\t\t\t\t<br /><strong>tax</strong> = ( string ), taxonomy name\n"
"\t\t\t\t<br /><strong>sep</strong> = ( string ), separate array meta value "
"into string\n"
"\t\t\t\t<br /><strong>return</strong> = ( name|slug ), return plain name or "
"slug"
msgstr ""

#: includes/template-tags/class-post-template-tags.php:376
msgid ""
"<strong>Output</strong>: if the post type is attachment, the attached file "
"thumb is displayed.\n"
"\t\t\t\t<br /><br /><strong>Attributes:</strong>\n"
"\t\t\t\t<br /><strong>id</strong> = ( string ), attachment id\n"
"\t\t\t\t<br /><strong>meta_key</strong> = ( string ), retrieve attachment "
"id from meta value\n"
"\t\t\t\t<br /><strong>size</strong> = ( string ), image size\n"
"\t\t\t\t<br /><strong>class</strong> = ( string ), class name for the image "
"( &lt;img /&gt; ) tag\n"
"\t\t\t\t<br /><strong>width</strong> = ( number ), image width\n"
"\t\t\t\t<br /><strong>height</strong> = ( number ), image height\n"
"\t\t\t\t<br /><strong>return</strong> = ( text|number ),\n"
"\t\t\t\t<br />----\"src\" - will return src of the attachment,\n"
"\t\t\t\t<br />----\"id\" - will return id of the attachment,\n"
"\t\t\t\t<br />----by default it will return image html"
msgstr ""

